{
  "models": {
    "providers": {
      "openai": {
        "baseUrl": "https://api.openai.com/v1",
        "apiKey": "${OPENAI_API_KEY}",
        "api": "openai-completions",
        "models": [
          {"id": "gpt-5", "name": "GPT-5"}
        ]
      },
      "dmr": {
        "baseUrl": "${DMR_BASE_URL}",
        "apiKey": "${OLLAMA_API_KEY}",
        "api": "openai-completions",
        "models": [
          {"id": "gpt-oss-vllm", "name": "GPT-OSS vLLM"},
          {"id": "llama3.2", "name": "Llama 3.2"}
        ]
      },
      "ollama": {
        "baseUrl": "${OLLAMA_BASE_URL}",
        "api": "ollama",
        "models": []
      }
    }
  },
  "agents": {
    "defaults": {
      "model": {
        "primary": "openai/gpt-5",
        "fallbacks": ["dmr/llama3.2"]
      }
    }
  },
  "tools": {
    "allow": []
  },
  "gateway": {
    "mode": "local",
    "bind": "lan",
    "controlUi": {
      "allowedOrigins": [
        "http://localhost:${OPENCLAW_PORT}",
        "http://127.0.0.1:${OPENCLAW_PORT}"
      ]
    },
    "auth": {
      "mode": "token",
      "token": "${OPENCLAW_GATEWAY_TOKEN}"
    }
  },
  "browser": {
    "enabled": true,
    "attachOnly": true,
    "defaultProfile": "remote",
    "profiles": {
      "remote": {
        "cdpUrl": "http://openclaw-sandbox-browser:9222",
        "color": "#FF4500"
      }
    }
  },
  "plugins": {
    "allow": [],
    "load": {
      "paths": []
    },
    "entries": {}
  }
}
